generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["metrics"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------
// ENUMS & SCALAR TYPES
// ---------------------------------------------------------

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  USER
  VIEWER
  CUSTOMER
}

enum OrderStatus {
  DRAFT
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum AssetStatus {
  ACTIVE
  IDLE
  UNDER_MAINTENANCE
  RETIRED
  SOLD
}

enum TransactionType {
  CREDIT
  DEBIT
  JOURNAL
  ADJUSTMENT
}

enum StockMovementType {
  PURCHASE
  SALE
  RETURN
  ADJUSTMENT
  MANUFACTURING
  TRANSFER
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

// ---------------------------------------------------------
// COMPOSITE TYPES
// ---------------------------------------------------------



// ---------------------------------------------------------
// TENANT & AUTH MODELS
// ---------------------------------------------------------

model Tenant {
  id               String    @id @default(uuid())
  name             String
  subdomain        String?   @unique
  domain           String?   @unique
  companyEmail     String
  companyPhone     String?
  address          Json?     // Using composite type Address
  logo             String?
  favicon          String?
  timezone         String    @default("UTC")
  locale           String    @default("en-US")
  currency         String    @default("USD")
  fiscalYearStart  Int       @default(1)  // Month (1-12)
  isActive         Boolean   @default(true)
  isTrial          Boolean   @default(true)
  trialEndsAt      DateTime?
  isSuspended      Boolean   @default(false)
  suspensionReason String?
  maxUsers         Int       @default(10)
  maxStorage       Int       @default(1024) // MB
  theme            Json?     // Custom theme configuration
  settings         Json?     // Tenant-specific settings
  metadata         Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Relations
  users            User[]
  userSessions     UserSession[]
  apiKeys          ApiKey[]
  auditLogs        AuditLog[]
  notificationLogs NotificationLog[]
  
  // Business Relations
  warehouses       Warehouse[]
  suppliers        Supplier[]
  customers        Customer[]
  products         Product[]
  categories       Category[]
  brands           Brand[]
  uom              UnitOfMeasure[]
  taxRates         TaxRate[]
  paymentTerms     PaymentTerm[]
  shippingMethods  ShippingMethod[]
  
  // Document Management
  docTypes         DocType[]
  docSequences     DocSequence[]
  flags            Flag[]
  approvals        Approval[]
  
  // Financial
  accounts         Account[]
  journals         Journal[]
  transactions     Transaction[]
  invoices         Invoice[]
  payments         Payment[]
  expenses         Expense[]
  
  // Inventory
  stockMovements   StockMovement[]
  stockTakes       StockTake[]
  stockAdjustments StockAdjustment[]
  transfers        Transfer[]
  
  // Manufacturing
  formulas         Formula[]
  formulaItems     FormulaItem[]
  workOrders       WorkOrder[]
  workOrderItems   WorkOrderItem[]
  productionPlans  ProductionPlan[]
  productionLines  ProductionLine[]
  
  // Assets
  assets           Asset[]
  assetCategories  AssetCategory[]
  assetMaintenance AssetMaintenance[]
  assetDepreciation AssetDepreciation[]

  // Supply Chain
  purchaseOrders   PurchaseOrder[]
  salesOrders      SalesOrder[]
  quotations       Quotation[]
  deliveryNotes    DeliveryNote[]
  
  // Analytics
  reports          Report[]
  dashboards       Dashboard[]

  // Other references
  stockItems      StockItem[]
  orderItems      OrderItem[]
  
  @@index([isActive])
  @@index([subdomain])
  @@index([createdAt])
}

model User {
  id                 String    @id @default(uuid())
  tenantId           String
  email              String    @unique
  emailVerified      Boolean   @default(false)
  username           String
  passwordHash       String
  passwordChangedAt  DateTime?
  role               UserRole  @default(USER)
  firstName          String?
  lastName           String?
  avatar             String?
  phone              String?
  department         String?
  position           String?
  isActive           Boolean   @default(true)
  isLocked           Boolean   @default(false)
  failedLoginAttempts Int      @default(0)
  lastLoginAt        DateTime?
  lastLoginIp        String?
  lastActiveAt       DateTime?
  timezone           String    @default("UTC")
  locale             String    @default("en-US")
  preferences        Json?
  metadata           Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deactivatedAt      DateTime?

  tenant             Tenant    @relation(fields: [tenantId], references: [id])
  sessions           UserSession[]
  auditLogs          AuditLog[]
  approvals          Approval[]
  workOrdersAssigned WorkOrder[] @relation("WorkOrderAssignments")
  workOrdersCreated  WorkOrder[] @relation("WorkOrderCreatedBy")
  transactions       Transaction[]
  
  managedWarehouses  Warehouse[]
  notificationLogs   NotificationLog[]


  @@unique([tenantId, email])
  @@index([tenantId, role])
  @@index([tenantId, isActive])
  @@index([lastActiveAt])
}

model UserSession {
  id           String   @id @default(uuid())
  userId       String
  tenantId     String
  sessionToken String   @unique
  refreshToken String?  @unique
  ipAddress    String?
  userAgent    String?
  deviceInfo   Json?
  location     Json?
  isValid      Boolean  @default(true)
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  lastUsedAt   DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id])
  tenant       Tenant   @relation(fields: [tenantId], references: [id])

  @@index([userId])
  @@index([expiresAt])
  @@index([tenantId, isValid])
}

model ApiKey {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  keyHash     String   @unique
  prefix      String
  permissions Json
  expiresAt   DateTime?
  lastUsedAt  DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, name])
  @@index([prefix])
  @@index([expiresAt])
}

// ---------------------------------------------------------
// AUDIT & LOGGING
// ---------------------------------------------------------

model AuditLog {
  id          String   @id @default(uuid())
  tenantId    String
  userId      String?
  entityType  String   // e.g., "Order", "Product"
  entityId    String
  action      String   // CREATE, UPDATE, DELETE, VIEW
  oldData     Json?
  newData     Json?
  changes     Json?
  ipAddress   String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, createdAt])
  @@index([userId])
}

model NotificationLog {
  id          String   @id @default(uuid())
  tenantId    String
  userId      String?
  type        String   // EMAIL, SMS, PUSH, IN_APP
  channel     String
  recipient   String
  subject     String?
  content     Json
  status      String   // SENT, DELIVERED, FAILED, READ
  error       String?
  metadata    Json?
  sentAt      DateTime?
  readAt      DateTime?
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])

  @@index([tenantId, status])
  @@index([recipient])
  @@index([createdAt])
}

// ---------------------------------------------------------
// MASTER DATA MANAGEMENT
// ---------------------------------------------------------

model UnitOfMeasure {
  id          String   @id @default(uuid())
  tenantId    String
  name        String   // e.g., "Kilogram", "Liter", "Piece"
  code        String   // e.g., "KG", "L", "PC"
  symbol      String?  // e.g., "kg", "l", "pcs"
  category    String?  // Weight, Volume, Length, Quantity
  baseUnit    Boolean  @default(false)
  conversion  Decimal? @db.Decimal(19, 6) // Conversion to base unit
  isActive    Boolean  @default(true)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  products    Product[]
  formulaItems FormulaItem[]

  @@unique([tenantId, code])
  @@unique([tenantId, name])
}

model Brand {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  logo        String?
  description String?
  website     String?
  isActive    Boolean  @default(true)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  products    Product[]

  @@unique([tenantId, name])
}

model TaxRate {
  id          String   @id @default(uuid())
  tenantId    String
  name        String   // e.g., "GST", "VAT", "Sales Tax"
  code        String
  rate        Decimal  @db.Decimal(5, 3) // e.g., 0.18 for 18%
  isCompound  Boolean  @default(false)
  isActive    Boolean  @default(true)
  effectiveFrom DateTime @default(now())
  effectiveTo  DateTime?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  products    Product[]

  @@unique([tenantId, code])
}

model PaymentTerm {
  id          String   @id @default(uuid())
  tenantId    String
  name        String   // e.g., "Net 30", "Due on Receipt"
  code        String
  days        Int
  discountDays Int?
  discountRate Decimal? @db.Decimal(5, 2)
  isActive    Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  customers   Customer[]
  suppliers   Supplier[]
  salesOrders SalesOrder[]
  purchaseOrders PurchaseOrder[]

  @@unique([tenantId, code])
}

model ShippingMethod {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  code        String
  carrier     String?
  cost        Decimal  @db.Decimal(19, 4) @default(0.00)
  isActive    Boolean  @default(true)
  estimatedDays Int?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  salesOrders SalesOrder[]

  @@unique([tenantId, code])
}

// ---------------------------------------------------------
// DOCUMENT MANAGEMENT
// ---------------------------------------------------------

model DocType {
  id           String   @id @default(uuid())
  tenantId     String
  name         String
  code         String
  description  String?
  prefix       String?
  isSystem     Boolean  @default(false)
  isActive     Boolean  @default(true)
  workflow     Json?    // JSON configuration for approval workflow
  printTemplate String?
  metadata     Json?
  audit        Json?    // Embedded AuditMetadata

  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  docSequences DocSequence[]
  approvals    Approval[]
  salesOrders    SalesOrder[]
  purchaseOrders PurchaseOrder[]
  quotations     Quotation[]
  journals     Journal[]
  invoices     Invoice[]

  @@unique([tenantId, code])
  @@unique([tenantId, name])
}

model DocSequence {
  id          String   @id @default(uuid())
  tenantId    String
  docTypeId   String
  prefix      String?
  suffix      String?
  separator   String   @default("/")
  nextNumber  Int      @default(1)
  year        Int?     // For yearly reset
  month       Int?     // For monthly reset
  resetType   String   @default("CONTINUOUS") // CONTINUOUS, YEARLY, MONTHLY
  format      String   @default("{prefix}{number}{suffix}")
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  docType     DocType  @relation(fields: [docTypeId], references: [id])

  @@unique([tenantId, docTypeId])
}

model Flag {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  code        String
  description String?
  color       String   @default("#808080")
  icon        String?
  isActive    Boolean  @default(true)
  metadata    Json?
  audit       Json?    // Embedded AuditMetadata

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  salesOrders    SalesOrder[]
  purchaseOrders PurchaseOrder[]

  @@unique([tenantId, code])
  @@unique([tenantId, name])
}

model Approval {
  id             String        @id @default(uuid())
  tenantId       String
  docTypeId      String
  documentId     String
  documentType   String        // e.g., "Order", "Invoice", "Expense"
  currentLevel   Int           @default(1)
  totalLevels    Int           @default(1)
  status         ApprovalStatus @default(PENDING)
  approvers      Json          // Array of approver configs
  actions        Json          // Approval history
  comments       String?
  metadata       Json?
  approvedAt     DateTime?
  rejectedAt     DateTime?
  expiresAt      DateTime?
  audit          Json?         // Embedded AuditMetadata

  tenant         Tenant        @relation(fields: [tenantId], references: [id])
  docType        DocType?      @relation(fields: [docTypeId], references: [id])
  assignedUsers  User[]

  @@index([tenantId, documentType, documentId])
  @@index([tenantId, status])
  @@index([expiresAt])
}

// ---------------------------------------------------------
// INVENTORY & WAREHOUSING
// ---------------------------------------------------------

model Warehouse {
  id          String   @id @default(uuid())
  tenantId    String
  code        String
  name        String
  type        String   @default("STORAGE") // STORAGE, RETAIL, PRODUCTION
  address     Json?
  contactInfo Json?
  managerId   String?
  isActive    Boolean  @default(true)
  capacity    Decimal? @db.Decimal(19, 4) // Total capacity in base UOM
  currentUtilization Decimal? @db.Decimal(19, 4)
  temperatureZone String?
  metadata    Json?
  audit       Json?    // Embedded AuditMetadata

  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  manager     User?    @relation(fields: [managerId], references: [id])
  stockItems  StockItem[]
  stockTakes  StockTake[]
  outgoingTransfers Transfer[] @relation("TransfersFrom")
  incomingTransfers Transfer[] @relation("TransfersTo")
  salesOrders       SalesOrder[]
  purchaseOrders    PurchaseOrder[]
  assets      Asset[]
  workOrders  WorkOrder[]

  @@unique([tenantId, code])
  @@unique([tenantId, name])
}

model StockItem {
  id              String   @id @default(uuid())
  tenantId        String
  productId       String
  warehouseId     String
  sku             String?  // Warehouse-specific SKU
  batchNumber     String?
  serialNumber    String?
  expiryDate      DateTime?
  manufactureDate DateTime?
  quantity        Decimal  @db.Decimal(19, 4) @default(0.00)
  reservedQuantity Decimal @db.Decimal(19, 4) @default(0.00)
  availableQuantity Decimal @db.Decimal(19, 4) @default(0.00)
  averageCost     Decimal  @db.Decimal(19, 4) @default(0.00)
  lastCost        Decimal  @db.Decimal(19, 4) @default(0.00)
  minLevel        Decimal? @db.Decimal(19, 4)
  maxLevel        Decimal? @db.Decimal(19, 4)
  reorderPoint    Decimal? @db.Decimal(19, 4)
  location        String?  // Rack/Shelf/Bin location
  status          String   @default("AVAILABLE") // AVAILABLE, RESERVED, QUARANTINE
  metadata        Json?
  lastCountedAt   DateTime?
  audit           Json?    // Embedded AuditMetadata
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  tenant          Tenant     @relation(fields: [tenantId], references: [id])
  product         Product    @relation(fields: [productId], references: [id])
  warehouse       Warehouse  @relation(fields: [warehouseId], references: [id])
  stockMovements  StockMovement[]
  adjustments     StockAdjustment[]

  @@unique([tenantId, productId, warehouseId, batchNumber, serialNumber])
  @@index([tenantId, warehouseId])
  @@index([expiryDate])
  @@index([sku])
}

model StockMovement {
  id               String            @id @default(uuid())
  tenantId         String
  stockItemId      String
  referenceType    String            // ORDER, TRANSFER, ADJUSTMENT, MANUFACTURING
  referenceId      String
  movementType     StockMovementType
  quantityBefore   Decimal           @db.Decimal(19, 4)
  quantityChange   Decimal           @db.Decimal(19, 4)
  quantityAfter    Decimal           @db.Decimal(19, 4)
  cost             Decimal?          @db.Decimal(19, 4)
  value            Decimal?          @db.Decimal(19, 4)
  reason           String?
  notes            String?
  movementDate     DateTime          @default(now())
  metadata         Json?
  audit            Json?             // Embedded AuditMetadata

  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  stockItem        StockItem         @relation(fields: [stockItemId], references: [id])

  @@index([tenantId, referenceType, referenceId])
  @@index([tenantId, movementDate])
  @@index([stockItemId])
}

model StockTake {
  id           String   @id @default(uuid())
  tenantId     String
  warehouseId  String
  code         String
  status       String   @default("PLANNED") // PLANNED, IN_PROGRESS, COMPLETED, ADJUSTED
  startDate    DateTime?
  endDate      DateTime?
  countedBy    String?
  verifiedBy   String?
  totalItems   Int      @default(0)
  itemsCounted Int      @default(0)
  variance     Decimal? @db.Decimal(19, 4)
  notes        String?
  metadata     Json?
  audit        Json?    // Embedded AuditMetadata

  tenant       Tenant     @relation(fields: [tenantId], references: [id])
  warehouse    Warehouse  @relation(fields: [warehouseId], references: [id])
  adjustments  StockAdjustment[]

  @@unique([tenantId, code])
  @@index([tenantId, warehouseId, status])
}

model StockAdjustment {
  id           String   @id @default(uuid())
  tenantId     String
  stockTakeId  String?
  stockItemId  String
  type         String   @default("PHYSICAL") // PHYSICAL, SYSTEM, VALUE
  quantityBefore Decimal @db.Decimal(19, 4)
  quantityAfter  Decimal @db.Decimal(19, 4)
  quantityChange Decimal @db.Decimal(19, 4)
  costBefore   Decimal? @db.Decimal(19, 4)
  costAfter    Decimal? @db.Decimal(19, 4)
  reason       String
  notes        String?
  adjustedBy   String
  adjustedAt   DateTime @default(now())
  metadata     Json?
  audit        Json?    // Embedded AuditMetadata

  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  stockTake    StockTake? @relation(fields: [stockTakeId], references: [id])
  stockItem    StockItem  @relation(fields: [stockItemId], references: [id])

  @@index([tenantId, adjustedAt])
  @@index([stockItemId])
}

model Transfer {
  id           String   @id @default(uuid())
  tenantId     String
  code         String
  fromWarehouseId String
  toWarehouseId   String
  status       String   @default("DRAFT") // DRAFT, REQUESTED, APPROVED, IN_TRANSIT, RECEIVED
  transferDate DateTime @default(now())
  expectedDeliveryDate DateTime?
  actualDeliveryDate DateTime?
  totalItems   Int      @default(0)
  totalValue   Decimal  @db.Decimal(19, 4) @default(0.00)
  notes        String?
  metadata     Json?
  audit        Json?    // Embedded AuditMetadata

  tenant       Tenant      @relation(fields: [tenantId], references: [id])
  fromWarehouse Warehouse  @relation("TransfersFrom", fields: [fromWarehouseId], references: [id])
  toWarehouse   Warehouse  @relation("TransfersTo", fields: [toWarehouseId], references: [id])
  items         TransferItem[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@index([transferDate])
}

model TransferItem {
  id           String   @id @default(uuid())
  transferId   String
  productId    String
  quantity     Decimal  @db.Decimal(19, 4)
  quantityReceived Decimal @db.Decimal(19, 4) @default(0.00)
  unitCost     Decimal  @db.Decimal(19, 4)
  totalCost    Decimal  @db.Decimal(19, 4)
  notes        String?
  metadata     Json?

  transfer     Transfer @relation(fields: [transferId], references: [id])
  product      Product  @relation(fields: [productId], references: [id])

  @@index([transferId])
}

// ---------------------------------------------------------
// PRODUCT CATALOG
// ---------------------------------------------------------

model Category {
  id          String     @id @default(uuid())
  tenantId    String
  parentId    String?
  code        String
  name        String
  description String?
  image       String?
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  attributes  Json?      // Custom attributes schema
  metadata    Json?
  audit       Json?      // Embedded AuditMetadata

  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  products    Product[]
  
  tenant      Tenant     @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, code])
  @@unique([tenantId, name])
  @@index([tenantId, parentId])
}

model Product {
  id              String   @id @default(uuid())
  tenantId        String
  categoryId      String?
  brandId         String?
  uomId           String?
  taxRateId       String?
  code            String   // Internal product code
  sku             String   // Stock Keeping Unit
  name            String
  description     String?
  longDescription String?
  barcode         String?  @unique
  upc             String?  @unique
  weight          Decimal? @db.Decimal(19, 4)
  weightUnit      String   @default("kg")
  dimensions      Json?    // {length, width, height, unit}
  images          Json?    // Array of image URLs
  documents       Json?    // Array of document URLs
  basePrice       Decimal  @db.Decimal(19, 4) @default(0.00)
  costPrice       Decimal  @db.Decimal(19, 4) @default(0.00)
  salePrice       Decimal  @db.Decimal(19, 4) @default(0.00)
  minPrice        Decimal? @db.Decimal(19, 4)
  maxPrice        Decimal? @db.Decimal(19, 4)
  isActive        Boolean  @default(true)
  isStockable     Boolean  @default(true)
  isPurchasable   Boolean  @default(true)
  isSellable      Boolean  @default(true)
  isManufactured  Boolean  @default(false)
  trackInventory  Boolean  @default(true)
  trackSerial     Boolean  @default(false)
  trackBatch      Boolean  @default(false)
  shelfLifeDays   Int?
  reorderPoint    Decimal? @db.Decimal(19, 4)
  reorderQuantity Decimal? @db.Decimal(19, 4)
  totalQuantity   Decimal  @db.Decimal(19, 4) @default(0.00) // Across all warehouses
  reservedQuantity Decimal @db.Decimal(19, 4) @default(0.00)
  availableQuantity Decimal @db.Decimal(19, 4) @default(0.00)
  attributes      Json?    // Custom attributes
  specifications  Json?    // Technical specifications
  metadata        Json?
  audit           Json?    // Embedded AuditMetadata

  tenant          Tenant       @relation(fields: [tenantId], references: [id])
  category        Category?    @relation(fields: [categoryId], references: [id])
  brand           Brand?       @relation(fields: [brandId], references: [id])
  uom             UnitOfMeasure? @relation(fields: [uomId], references: [id])
  taxRate         TaxRate?     @relation(fields: [taxRateId], references: [id])
  stockItems      StockItem[]
  orderItems      OrderItem[]
  transferItems   TransferItem[]
  formula         Formula?     // For manufactured products
  workOrderItems  WorkOrderItem[]
  invoiceItems    InvoiceItem[]
  deliveryItems   DeliveryItem[]
  formulaItems    FormulaItem[]
  productionLines ProductionLine[]

  @@unique([tenantId, code])
  @@unique([tenantId, sku])
  @@index([tenantId, categoryId])
  @@index([tenantId, isActive])
  @@index([tenantId, isStockable])
  @@index([sku])
}

// ---------------------------------------------------------
// SUPPLIERS & CUSTOMERS
// ---------------------------------------------------------

model Supplier {
  id              String   @id @default(uuid())
  tenantId        String
  code            String
  name            String
  companyName     String
  type            String   @default("VENDOR") // VENDOR, MANUFACTURER, DISTRIBUTOR
  taxId           String?
  currency        String   @default("USD")
  paymentTermId   String?
  address         Json?
  contactInfo     Json?
  primaryContact  Json?    // {name, email, phone, position}
  contacts        Json?    // Array of additional contacts
  bankDetails     Json?
  rating          Int?     @default(0)
  creditLimit     Decimal? @db.Decimal(19, 4)
  currentBalance  Decimal  @db.Decimal(19, 4) @default(0.00)
  totalPurchases  Decimal  @db.Decimal(19, 4) @default(0.00)
  lastPurchaseDate DateTime?
  isActive        Boolean  @default(true)
  isVerified      Boolean  @default(false)
  metadata        Json?
  audit           Json?    // Embedded AuditMetadata

  tenant          Tenant      @relation(fields: [tenantId], references: [id])
  paymentTerm     PaymentTerm? @relation(fields: [paymentTermId], references: [id])
  purchaseOrders  PurchaseOrder[]
  invoices        Invoice[]
  payments        Payment[]

  @@unique([tenantId, code])
  @@unique([tenantId, taxId])
  @@index([tenantId, isActive])
  @@index([tenantId, name])
}

model Customer {
  id              String   @id @default(uuid())
  tenantId        String
  code            String
  type            String   @default("INDIVIDUAL") // INDIVIDUAL, COMPANY
  firstName       String?
  lastName        String?
  companyName     String?
  displayName     String
  taxId           String?
  currency        String   @default("USD")
  paymentTermId   String?
  address         Json?
  billingAddress  Json?
  shippingAddress Json?
  contactInfo     Json?
  primaryContact  Json?    // {name, email, phone, position}
  contacts        Json?    // Array of additional contacts
  priceGroup      String?  // For customer-specific pricing
  discountRate    Decimal? @db.Decimal(5, 2)
  creditLimit     Decimal? @db.Decimal(19, 4)
  currentBalance  Decimal  @db.Decimal(19, 4) @default(0.00)
  totalSales      Decimal  @db.Decimal(19, 4) @default(0.00)
  lastSaleDate    DateTime?
  isActive        Boolean  @default(true)
  isPortalUser    Boolean  @default(false)
  portalUserId    String?
  metadata        Json?
  audit           Json?    // Embedded AuditMetadata
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  tenant          Tenant      @relation(fields: [tenantId], references: [id])
  paymentTerm     PaymentTerm? @relation(fields: [paymentTermId], references: [id])
  salesOrders     SalesOrder[]
  quotations      Quotation[]
  invoices        Invoice[]
  payments        Payment[]

  @@unique([tenantId, code])
  @@unique([tenantId, taxId])
  @@unique([portalUserId])
  @@index([tenantId, isActive])
  @@index([tenantId, displayName])
}

// ---------------------------------------------------------
// SALES & PURCHASING
// ---------------------------------------------------------

model SalesOrder {
  id              String   @id @default(uuid())
  tenantId        String
  customerId      String
  docTypeId       String?
  quotationId     String?
  code            String
  status          OrderStatus @default(DRAFT)
  orderDate       DateTime @default(now())
  deliveryDate    DateTime?
  paymentTermId   String?
  shippingMethodId String?
  warehouseId     String?
  subtotal        Decimal  @db.Decimal(19, 4) @default(0.00)
  taxAmount       Decimal  @db.Decimal(19, 4) @default(0.00)
  discountAmount  Decimal  @db.Decimal(19, 4) @default(0.00)
  shippingAmount  Decimal  @db.Decimal(19, 4) @default(0.00)
  totalAmount     Decimal  @db.Decimal(19, 4) @default(0.00)
  paidAmount      Decimal  @db.Decimal(19, 4) @default(0.00)
  dueAmount       Decimal  @db.Decimal(19, 4) @default(0.00)
  notes           String?
  internalNotes   String?
  metadata        Json?
  audit           Json?    // Embedded AuditMetadata

  tenant          Tenant         @relation(fields: [tenantId], references: [id])
  docType         DocType?       @relation(fields: [docTypeId], references: [id])
  customer        Customer       @relation(fields: [customerId], references: [id])
  paymentTerm     PaymentTerm?   @relation(fields: [paymentTermId], references: [id])
  shippingMethod  ShippingMethod? @relation(fields: [shippingMethodId], references: [id])
  quotation       Quotation?     @relation("QuotationToSalesOrder", fields: [quotationId], references: [id])
  warehouse       Warehouse?     @relation(fields: [warehouseId], references: [id])
  items           OrderItem[]
  invoices        Invoice[]
  deliveries      DeliveryNote[]
  flags           Flag[]

  @@unique([tenantId, code])
  @@index([tenantId, customerId])
  @@index([tenantId, status])
  @@index([orderDate])
}

model PurchaseOrder {
  id              String   @id @default(uuid())
  tenantId        String
  supplierId      String
  docTypeId       String?
  code            String
  status          OrderStatus @default(DRAFT)
  orderDate       DateTime @default(now())
  expectedDate    DateTime?
  deliveryDate    DateTime?
  paymentTermId   String?
  warehouseId     String?
  subtotal        Decimal  @db.Decimal(19, 4) @default(0.00)
  taxAmount       Decimal  @db.Decimal(19, 4) @default(0.00)
  discountAmount  Decimal  @db.Decimal(19, 4) @default(0.00)
  shippingAmount  Decimal  @db.Decimal(19, 4) @default(0.00)
  totalAmount     Decimal  @db.Decimal(19, 4) @default(0.00)
  notes           String?
  internalNotes   String?
  metadata        Json?
  audit           Json?    // Embedded AuditMetadata

  tenant          Tenant      @relation(fields: [tenantId], references: [id])
  docType         DocType?    @relation(fields: [docTypeId], references: [id])
  supplier        Supplier    @relation(fields: [supplierId], references: [id])
  paymentTerm     PaymentTerm? @relation(fields: [paymentTermId], references: [id])
  warehouse       Warehouse?  @relation(fields: [warehouseId], references: [id])
  items           OrderItem[]
  invoices        Invoice[]
  flags           Flag[]

  @@unique([tenantId, code])
  @@index([tenantId, supplierId])
  @@index([tenantId, status])
  @@index([orderDate])
}

model Quotation {
  id              String   @id @default(uuid())
  tenantId        String
  customerId      String
  docTypeId       String?
  code            String
  status          String   @default("DRAFT") // DRAFT, SENT, ACCEPTED, REJECTED, EXPIRED
  quoteDate       DateTime @default(now())
  expiryDate      DateTime
  subtotal        Decimal  @db.Decimal(19, 4) @default(0.00)
  taxAmount       Decimal  @db.Decimal(19, 4) @default(0.00)
  discountAmount  Decimal  @db.Decimal(19, 4) @default(0.00)
  totalAmount     Decimal  @db.Decimal(19, 4) @default(0.00)
  notes           String?
  terms           String?
  metadata        Json?
  audit           Json?    // Embedded AuditMetadata

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  docType         DocType? @relation(fields: [docTypeId], references: [id])
  customer        Customer @relation(fields: [customerId], references: [id])
  items           OrderItem[]
  salesOrders     SalesOrder[] @relation("QuotationToSalesOrder")

  @@unique([tenantId, code])
  @@index([tenantId, customerId])
  @@index([tenantId, status])
  @@index([expiryDate])
}

model OrderItem {
  id              String   @id @default(uuid())
  tenantId        String
  salesOrderId    String?
  purchaseOrderId String?
  quotationId     String?
  productId       String
  quantity        Decimal  @db.Decimal(19, 4)
  deliveredQuantity Decimal @db.Decimal(19, 4) @default(0.00)
  invoicedQuantity Decimal @db.Decimal(19, 4) @default(0.00)
  unitPrice       Decimal  @db.Decimal(19, 4)
  discountRate    Decimal  @db.Decimal(5, 2) @default(0.00)
  discountAmount  Decimal  @db.Decimal(19, 4) @default(0.00)
  taxRate         Decimal  @db.Decimal(5, 2) @default(0.00)
  taxAmount       Decimal  @db.Decimal(19, 4) @default(0.00)
  lineTotal       Decimal  @db.Decimal(19, 4) @default(0.00)
  notes           String?
  metadata        Json?
  deliveryItems   DeliveryItem[]

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  product         Product  @relation(fields: [productId], references: [id])
  salesOrder      SalesOrder?   @relation(fields: [salesOrderId], references: [id])
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  quotation       Quotation?    @relation(fields: [quotationId], references: [id])

  @@index([salesOrderId])
  @@index([purchaseOrderId])
  @@index([quotationId])
  @@index([productId])
}

// ---------------------------------------------------------
// INVOICING & PAYMENTS
// ---------------------------------------------------------

model Invoice {
  id              String   @id @default(uuid())
  tenantId        String
  docTypeId       String
  invoiceNumber   String
  referenceType   String?   // SALES_ORDER, PURCHASE_ORDER
  referenceId     String?
  salesOrderId    String?
  purchaseOrderId String?
  customerId      String?
  supplierId      String?
  invoiceDate     DateTime @default(now())
  dueDate         DateTime
  subtotal        Decimal  @db.Decimal(19, 4) @default(0.00)
  taxAmount       Decimal  @db.Decimal(19, 4) @default(0.00)
  discountAmount  Decimal  @db.Decimal(19, 4) @default(0.00)
  totalAmount     Decimal  @db.Decimal(19, 4) @default(0.00)
  paidAmount      Decimal  @db.Decimal(19, 4) @default(0.00)
  dueAmount       Decimal  @db.Decimal(19, 4) @default(0.00)
  currency        String   @default("USD")
  exchangeRate    Decimal  @db.Decimal(19, 6) @default(1.00)
  status          String   @default("DRAFT") // DRAFT, ISSUED, PARTIAL, PAID, OVERDUE, CANCELLED
  paymentTerms    String?
  notes           String?
  metadata        Json?
  audit           Json?    // Embedded AuditMetadata

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  docType         DocType  @relation(fields: [docTypeId], references: [id])
  salesOrder      SalesOrder?   @relation(fields: [salesOrderId], references: [id])
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  customer        Customer? @relation(fields: [customerId], references: [id])
  supplier        Supplier? @relation(fields: [supplierId], references: [id])
  items           InvoiceItem[]
  payments        Payment[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId, referenceType, referenceId])
  @@index([tenantId, status])
  @@index([dueDate])
}

model InvoiceItem {
  id              String   @id @default(uuid())
  invoiceId       String
  productId       String
  description     String?
  quantity        Decimal  @db.Decimal(19, 4)
  unitPrice       Decimal  @db.Decimal(19, 4)
  discountRate    Decimal  @db.Decimal(5, 2) @default(0.00)
  discountAmount  Decimal  @db.Decimal(19, 4) @default(0.00)
  taxRate         Decimal  @db.Decimal(5, 2) @default(0.00)
  taxAmount       Decimal  @db.Decimal(19, 4) @default(0.00)
  lineTotal       Decimal  @db.Decimal(19, 4) @default(0.00)

  invoice         Invoice  @relation(fields: [invoiceId], references: [id])
  product         Product  @relation(fields: [productId], references: [id])

  @@index([invoiceId])
}

model Payment {
  id              String   @id @default(uuid())
  tenantId        String
  invoiceId       String?
  customerId      String?
  supplierId      String?
  paymentNumber   String
  paymentDate     DateTime @default(now())
  amount          Decimal  @db.Decimal(19, 4)
  currency        String   @default("USD")
  exchangeRate    Decimal  @db.Decimal(19, 6) @default(1.00)
  paymentMethod   String   // CASH, CARD, BANK_TRANSFER, CHECK, DIGITAL_WALLET
  referenceNumber String?
  bankAccount     Json?
  cardDetails     Json?
  status          String   @default("PENDING") // PENDING, COMPLETED, FAILED, REFUNDED
  notes           String?
  metadata        Json?
  audit           Json?    // Embedded AuditMetadata

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  invoice         Invoice? @relation(fields: [invoiceId], references: [id])
  customer        Customer? @relation(fields: [customerId], references: [id])
  supplier        Supplier? @relation(fields: [supplierId], references: [id])

  @@unique([tenantId, paymentNumber])
  @@index([tenantId, paymentDate])
  @@index([tenantId, status])
  @@index([referenceNumber])
}

model DeliveryNote {
  id              String   @id @default(uuid())
  tenantId        String
  salesOrderId    String
  deliveryNumber  String
  deliveryDate    DateTime @default(now())
  deliveredBy     String?
  receivedBy      String?
  status          String   @default("DRAFT") // DRAFT, DELIVERED, PARTIAL, CANCELLED
  notes           String?
  signature       String?  // Base64 signature image
  metadata        Json?
  audit           Json?    // Embedded AuditMetadata

  tenant          Tenant     @relation(fields: [tenantId], references: [id])
  salesOrder      SalesOrder @relation(fields: [salesOrderId], references: [id])
  items           DeliveryItem[]

  @@unique([tenantId, deliveryNumber])
  @@index([tenantId, salesOrderId])
  @@index([deliveryDate])
}

model DeliveryItem {
  id                String   @id @default(uuid())
  deliveryNoteId    String
  productId         String
  orderItemId       String?
  quantityOrdered   Decimal  @db.Decimal(19, 4)
  quantityDelivered Decimal  @db.Decimal(19, 4)
  notes             String?

  deliveryNote      DeliveryNote @relation(fields: [deliveryNoteId], references: [id])
  product           Product      @relation(fields: [productId], references: [id])
  orderItem         OrderItem?   @relation(fields: [orderItemId], references: [id])

  @@index([deliveryNoteId])
}

// ---------------------------------------------------------
// FINANCIALS & ACCOUNTING
// ---------------------------------------------------------

model Account {
  id              String   @id @default(uuid())
  tenantId        String
  parentId        String?
  code            String
  name            String
  type            String   // ASSET, LIABILITY, EQUITY, REVENUE, EXPENSE
  subtype         String?  // CURRENT_ASSET, FIXED_ASSET, etc.
  currency        String   @default("USD")
  openingBalance  Decimal  @db.Decimal(19, 4) @default(0.00)
  currentBalance  Decimal  @db.Decimal(19, 4) @default(0.00)
  isActive        Boolean  @default(true)
  isLocked        Boolean  @default(false)
  allowTransactions Boolean @default(true)
  description     String?
  metadata        Json?
  audit           Json?    // Embedded AuditMetadata

  parent          Account?  @relation("AccountHierarchy", fields: [parentId], references: [id])
  children        Account[] @relation("AccountHierarchy")
  tenant          Tenant    @relation(fields: [tenantId], references: [id])
  transactions    Transaction[]

  @@unique([tenantId, code])
  @@unique([tenantId, name])
  @@index([tenantId, type])
  @@index([tenantId, parentId])
}

model Journal {
  id              String   @id @default(uuid())
  tenantId        String
  docTypeId       String
  journalNumber   String
  journalDate     DateTime @default(now())
  period          String?  // YYYYMM format
  description     String
  totalDebit      Decimal  @db.Decimal(19, 4) @default(0.00)
  totalCredit     Decimal  @db.Decimal(19, 4) @default(0.00)
  status          String   @default("DRAFT") // DRAFT, POSTED, REVERSED
  isReversed      Boolean  @default(false)
  reversalId      String?  @unique
  notes           String?
  metadata        Json?
  audit           Json?    // Embedded AuditMetadata

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  docType         DocType  @relation(fields: [docTypeId], references: [id])
  transactions    Transaction[]
  reversal        Journal? @relation("JournalReversal", fields: [reversalId], references: [id])
  reversedJournal Journal? @relation("JournalReversal")

  @@unique([tenantId, journalNumber])
  @@index([tenantId, journalDate])
  @@index([tenantId, status])
  @@index([period])
}

model Transaction {
  id              String   @id @default(uuid())
  tenantId        String
  journalId       String?
  accountId       String
  entryType       String   @default("MANUAL") // MANUAL, SYSTEM, IMPORT
  transactionDate DateTime @default(now())
  amount          Decimal  @db.Decimal(19, 4)
  type            TransactionType
  currency        String   @default("USD")
  exchangeRate    Decimal  @db.Decimal(19, 6) @default(1.00)
  baseAmount      Decimal  @db.Decimal(19, 4) // Amount in base currency
  description     String?
  referenceType   String?  // INVOICE, PAYMENT, EXPENSE
  referenceId     String?
  expenseId       String?
  userId          String?
  isReconciled    Boolean  @default(false)
  reconciledAt    DateTime?
  metadata        Json?
  audit           Json?    // Embedded AuditMetadata

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  journal         Journal? @relation(fields: [journalId], references: [id])
  account         Account  @relation(fields: [accountId], references: [id])
  expense         Expense? @relation(fields: [expenseId], references: [id])
  user            User?    @relation(fields: [userId], references: [id])

  @@index([tenantId, accountId])
  @@index([tenantId, transactionDate])
  @@index([tenantId, referenceType, referenceId])
  @@index([tenantId, isReconciled])
}

model Expense {
  id              String   @id @default(uuid())
  tenantId        String
  expenseNumber   String
  expenseDate     DateTime @default(now())
  category        String
  description     String
  amount          Decimal  @db.Decimal(19, 4)
  taxAmount       Decimal  @db.Decimal(19, 4) @default(0.00)
  totalAmount     Decimal  @db.Decimal(19, 4)
  currency        String   @default("USD")
  paymentMethod   String
  vendorName      String?
  receiptImage    String?
  isReimbursable  Boolean  @default(false)
  status          String   @default("PENDING") // PENDING, APPROVED, REIMBURSED
  notes           String?
  metadata        Json?
  audit           Json?    // Embedded AuditMetadata

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  transactions    Transaction[]

  @@unique([tenantId, expenseNumber])
  @@index([tenantId, expenseDate])
  @@index([tenantId, category])
  @@index([tenantId, status])
}

// ---------------------------------------------------------
// MANUFACTURING
// ---------------------------------------------------------

model Formula {
  id              String   @id @default(uuid())
  tenantId        String
  productId       String   @unique // Output product
  code            String
  name            String
  version         String   @default("1.0")
  isActive        Boolean  @default(true)
  batchSize       Decimal  @db.Decimal(19, 4) @default(1.00)
  yield           Decimal  @db.Decimal(5, 2) @default(100.00) // Percentage
  scrapRate       Decimal  @db.Decimal(5, 2) @default(0.00) // Percentage
  productionTime  Decimal? @db.Decimal(19, 4) // Hours per batch
  instructions    String?
  metadata        Json?
  audit           Json?    // Embedded AuditMetadata

  tenant          Tenant       @relation(fields: [tenantId], references: [id])
  product         Product      @relation(fields: [productId], references: [id])
  items           FormulaItem[]
  workOrders      WorkOrder[]

  @@unique([tenantId, code, version])
  @@index([tenantId, productId])
}

model FormulaItem {
  id              String   @id @default(uuid())
  tenantId        String
  formulaId       String
  productId       String
  quantity        Decimal  @db.Decimal(19, 4)
  uomId           String?
  scrapRate       Decimal  @db.Decimal(5, 2) @default(0.00)
  cost            Decimal? @db.Decimal(19, 4)
  sequence        Int
  notes           String?
  metadata        Json?

  tenant          Tenant       @relation(fields: [tenantId], references: [id])
  formula         Formula      @relation(fields: [formulaId], references: [id])
  product         Product      @relation(fields: [productId], references: [id])
  uom             UnitOfMeasure? @relation(fields: [uomId], references: [id])

  @@index([tenantId, formulaId])
  @@index([productId])
}

model WorkOrder {
  id              String   @id @default(uuid())
  tenantId        String
  formulaId       String
  warehouseId     String
  code            String
  status          String   @default("PLANNED") // PLANNED, RELEASED, IN_PROGRESS, COMPLETED, CANCELLED
  priority        String   @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  quantity        Decimal  @db.Decimal(19, 4)
  completedQuantity Decimal @db.Decimal(19, 4) @default(0.00)
  scrapQuantity   Decimal  @db.Decimal(19, 4) @default(0.00)
  plannedStart    DateTime?
  plannedFinish   DateTime?
  actualStart     DateTime?
  actualFinish    DateTime?
  assignedToId    String?
  createdById     String?
  notes           String?
  metadata        Json?
  audit           Json?    // Embedded AuditMetadata

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  formula         Formula  @relation(fields: [formulaId], references: [id])
  warehouse       Warehouse @relation(fields: [warehouseId], references: [id])
  assignedTo      User?    @relation("WorkOrderAssignments", fields: [assignedToId], references: [id])
  createdBy       User?    @relation("WorkOrderCreatedBy", fields: [createdById], references: [id])
  items           WorkOrderItem[]
  productionLines ProductionLine[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@index([tenantId, assignedToId])
  @@index([plannedStart])
  @@index([actualStart])
}

model WorkOrderItem {
  id              String   @id @default(uuid())
  tenantId        String
  workOrderId     String
  productId       String
  type            String   @default("RAW") // RAW, FINISHED, BYPRODUCT
  plannedQuantity Decimal  @db.Decimal(19, 4)
  issuedQuantity  Decimal  @db.Decimal(19, 4) @default(0.00)
  consumedQuantity Decimal @db.Decimal(19, 4) @default(0.00)
  scrapQuantity   Decimal  @db.Decimal(19, 4) @default(0.00)
  status          String   @default("PENDING") // PENDING, ISSUED, CONSUMED, CANCELLED
  notes           String?
  metadata        Json?

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  workOrder       WorkOrder @relation(fields: [workOrderId], references: [id])
  product         Product  @relation(fields: [productId], references: [id])

  @@index([tenantId, workOrderId])
  @@index([productId])
}

model ProductionPlan {
  id              String   @id @default(uuid())
  tenantId        String
  code            String
  name            String
  planType        String   @default("DAILY") // DAILY, WEEKLY, MONTHLY, CUSTOM
  startDate       DateTime
  endDate         DateTime
  status          String   @default("DRAFT") // DRAFT, ACTIVE, COMPLETED, CANCELLED
  totalOrders     Int      @default(0)
  completedOrders Int      @default(0)
  notes           String?
  metadata        Json?
  audit           Json?    // Embedded AuditMetadata

  tenant          Tenant         @relation(fields: [tenantId], references: [id])
  productionLines ProductionLine[]

  @@unique([tenantId, code])
  @@index([tenantId, startDate, endDate])
  @@index([tenantId, status])
}

model ProductionLine {
  id               String   @id @default(uuid())
  tenantId         String
  productionPlanId String?
  workOrderId      String?
  lineCode         String
  productId        String
  plannedQuantity  Decimal  @db.Decimal(19, 4)
  actualQuantity   Decimal  @db.Decimal(19, 4) @default(0.00)
  plannedStart     DateTime?
  plannedEnd       DateTime?
  actualStart      DateTime?
  actualEnd        DateTime?
  status           String   @default("PENDING") // PENDING, RUNNING, COMPLETED, CANCELLED
  efficiency       Decimal? @db.Decimal(5, 2)
  downtime         Int?     // Minutes
  notes            String?
  metadata         Json?

  tenant           Tenant        @relation(fields: [tenantId], references: [id])
  productionPlan   ProductionPlan? @relation(fields: [productionPlanId], references: [id])
  workOrder        WorkOrder?    @relation(fields: [workOrderId], references: [id])
  product          Product       @relation(fields: [productId], references: [id])

  @@unique([tenantId, lineCode])
  @@index([tenantId, productionPlanId])
  @@index([tenantId, workOrderId])
  @@index([plannedStart])
}

// ---------------------------------------------------------
// ASSET MANAGEMENT
// ---------------------------------------------------------

model AssetCategory {
  id              String   @id @default(uuid())
  tenantId        String
  parentId        String?
  code            String
  name            String
  description     String?
  depreciationMethod String @default("STRAIGHT_LINE") // STRAIGHT_LINE, DECLINING_BALANCE
  usefulLife      Int?     // Years
  residualValue   Decimal? @db.Decimal(5, 2) // Percentage
  isActive        Boolean  @default(true)
  metadata        Json?
  audit           Json?    // Embedded AuditMetadata

  parent          AssetCategory? @relation("AssetCategoryHierarchy", fields: [parentId], references: [id])
  children        AssetCategory[] @relation("AssetCategoryHierarchy")
  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  assets          Asset[]

  @@unique([tenantId, code])
  @@unique([tenantId, name])
  @@index([tenantId, parentId])
}

model Asset {
  id              String   @id @default(uuid())
  tenantId        String
  categoryId      String
  warehouseId     String?
  code            String
  name            String
  description     String?
  serialNumber    String?  @unique
  model           String?
  manufacturer    String?
  purchaseDate    DateTime?
  purchaseCost    Decimal  @db.Decimal(19, 4)
  currentValue    Decimal  @db.Decimal(19, 4)
  salvageValue    Decimal? @db.Decimal(19, 4)
  usefulLife      Int      // Years
  status          AssetStatus @default(ACTIVE)
  location        String?
  condition       String?  @default("GOOD") // GOOD, FAIR, POOR
  lastMaintenance DateTime?
  nextMaintenance DateTime?
  isInsured       Boolean  @default(false)
  insuranceDetails Json?
  metadata        Json?
  audit           Json?    // Embedded AuditMetadata
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  category        AssetCategory @relation(fields: [categoryId], references: [id])
  warehouse       Warehouse?    @relation(fields: [warehouseId], references: [id])
  allocations     AssetAllocation[]
  maintenance     AssetMaintenance[]
  depreciation    AssetDepreciation[]

  @@unique([tenantId, code])
  @@index([tenantId, categoryId])
  @@index([tenantId, status])
  @@index([serialNumber])
  @@index([nextMaintenance])
}

model AssetAllocation {
  id              String   @id @default(uuid())
  assetId         String
  assignedTo      String?  // User ID or Employee ID
  assignedToName  String?
  department      String?
  location        String?
  assignmentDate  DateTime @default(now())
  expectedReturn  DateTime?
  actualReturn    DateTime?
  conditionBefore String?
  conditionAfter  String?
  notes           String?
  metadata        Json?
  audit           Json?    // Embedded AuditMetadata

  asset           Asset    @relation(fields: [assetId], references: [id])

  @@index([assetId])
  @@index([assignedTo])
  @@index([assignmentDate])
}

model AssetMaintenance {
  id              String   @id @default(uuid())
  tenantId        String
  assetId         String
  maintenanceType String   @default("PREVENTIVE") // PREVENTIVE, CORRECTIVE, EMERGENCY
  scheduleType    String?  // DAILY, WEEKLY, MONTHLY, QUARTERLY, YEARLY
  maintenanceDate DateTime @default(now())
  nextDueDate     DateTime
  performedBy     String?
  cost            Decimal? @db.Decimal(19, 4)
  description     String
  notes           String?
  status          String   @default("PLANNED") // PLANNED, IN_PROGRESS, COMPLETED, CANCELLED
  metadata        Json?
  audit           Json?    // Embedded AuditMetadata

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  asset           Asset    @relation(fields: [assetId], references: [id])

  @@index([tenantId, assetId])
  @@index([tenantId, maintenanceDate])
  @@index([nextDueDate])
}

model AssetDepreciation {
  id              String   @id @default(uuid())
  tenantId        String
  assetId         String
  period          String   // YYYYMM format
  depreciationDate DateTime @default(now())
  beginningValue  Decimal  @db.Decimal(19, 4)
  depreciationAmount Decimal @db.Decimal(19, 4)
  endingValue     Decimal  @db.Decimal(19, 4)
  method          String   @default("STRAIGHT_LINE")
  rate            Decimal  @db.Decimal(5, 2)
  isPosted        Boolean  @default(false)
  postedAt        DateTime?
  metadata        Json?
  audit           Json?    // Embedded AuditMetadata

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  asset           Asset    @relation(fields: [assetId], references: [id])

  @@unique([tenantId, assetId, period])
  @@index([tenantId, period])
  @@index([tenantId, isPosted])
}

// ---------------------------------------------------------
// ANALYTICS & REPORTING
// ---------------------------------------------------------

model Report {
  id              String   @id @default(uuid())
  tenantId        String
  name            String
  code            String
  description     String?
  type            String   @default("STANDARD") // STANDARD, CUSTOM
  category        String   // SALES, INVENTORY, FINANCIAL, MANUFACTURING
  dataSource      String?
  query           String?
  parameters      Json?
  format          String   @default("TABLE") // TABLE, CHART, PIVOT
  chartType       String?  // BAR, LINE, PIE, etc.
  refreshInterval Int?     // Minutes
  isPublic        Boolean  @default(false)
  isScheduled     Boolean  @default(false)
  schedule        Json?
  lastRunAt       DateTime?
  metadata        Json?
  audit           Json?    // Embedded AuditMetadata

  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  dashboards      DashboardReport[]

  @@unique([tenantId, code])
  @@index([tenantId, category])
}

model Dashboard {
  id              String   @id @default(uuid())
  tenantId        String
  name            String
  description     String?
  layout          Json
  isDefault       Boolean  @default(false)
  isPublic        Boolean  @default(false)
  refreshInterval Int?     // Minutes
  metadata        Json?
  audit           Json?    // Embedded AuditMetadata

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  dashboardReports DashboardReport[]

  @@unique([tenantId, name])
}

model DashboardReport {
  id           String   @id @default(uuid())
  dashboardId  String
  reportId     String
  position     Json     // {x, y, w, h}
  settings     Json?
  sortOrder    Int      @default(0)

  dashboard    Dashboard @relation(fields: [dashboardId], references: [id])
  report       Report    @relation(fields: [reportId], references: [id])

  @@unique([dashboardId, reportId])
}

