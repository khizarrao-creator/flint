{
    "name": "@flint/database",
    "version": "1.0.0",
    "private": true,
    "main": "./index.ts",
    "types": "./index.ts",
    "scripts": {
        "db:generate": "dotenv -e ../../.env -- prisma generate",
        "db:push": "dotenv -e ../../.env -- prisma db push",
        "db:studio": "dotenv -e ../../.env -- prisma studio"
    },
    "dependencies": {
        "@prisma/client": "5.22.0",
        "@types/bcrypt": "^6.0.0",
        "bcrypt": "^6.0.0"
    },
    "devDependencies": {
        "@types/node": "^20.11.0",
        "prisma": "5.22.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.4.2"
    },
    "prisma": {
        "seed": "dotenv -e ../../.env -- ts-node prisma/seed.ts"
    }
}