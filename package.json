{
    "name": "flint-saas",
    "packageManager": "npm@10.9.3",
    "private": true,
    "scripts": {
        "build": "turbo build",
        "dev": "turbo dev",
        "lint": "turbo lint",
        "format": "prettier --write \"**/*.{ts,tsx,md}\"",
        "type-check": "turbo type-check"
    },
    "devDependencies": {
        "dotenv-cli": "^11.0.0",
        "prettier": "^3.2.5",
        "turbo": "latest"
    },
    "engines": {
        "node": ">=18"
    },
    "workspaces": [
        "apps/*",
        "packages/*"
    ]
}
